# Founder School Companion — environment config
#
# The app runs fully WITHOUT any of these (deterministic demo mode).
# Add a key to switch on live LLM answers. Any OpenAI-compatible endpoint works
# (OpenAI, OpenRouter, Groq, Azure, or a local Ollama/LM Studio server).

# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# PORT=3000
